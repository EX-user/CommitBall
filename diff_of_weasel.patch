+  if (!handled && !(keyEvent.mask & ibus::Modifier::RELEASE_MASK)) {
+    UINT vk = keyEvent.keycode;
+    if (vk >= 0x20 && vk <= 0x7E) {
+      bool shift = (GetAsyncKeyState(VK_SHIFT) & 0x8000) != 0;
+      bool caps = (GetKeyState(VK_CAPITAL) & 0x0001) != 0;
+      char ch = (char)vk;
+      if (vk >= 'A' && vk <= 'Z') {
+        if (!shift && !caps) ch = ch + 32;
+      } else if (shift) {
+        static const char* shiftMap = ")!@#$%^&*(";
+        if (vk >= '0' && vk <= '9') ch = shiftMap[vk - '0'];
+        else if (vk == 0xBD) ch = '_';
+        else if (vk == 0xBB) ch = '+';
+        else if (vk == 0xDB) ch = '{';
+        else if (vk == 0xDD) ch = '}';
+        else if (vk == 0xDC) ch = '|';
+        else if (vk == 0xBA) ch = ':';
+        else if (vk == 0xDE) ch = '"';
+        else if (vk == 0xBC) ch = '<';
+        else if (vk == 0xBE) ch = '>';
+        else if (vk == 0xBF) ch = '?';
+        else if (vk == 0xC0) ch = '~';
+      }
+      commitball::NotifyKeystroke((wchar_t)ch);
+    }
+  }
   return (BOOL)handled;
 }
 
