<Window x:Class="CommitBallBar.BarWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="CommitBall-Bar"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        Topmost="True"
        ResizeMode="NoResize"
        SizeToContent="Height"
        Width="460"
        Visibility="Hidden"
        Loaded="Window_Loaded">
    <Border x:Name="RootBorder" 
            CornerRadius="14" 
            Background="#2D2253" 
            BorderBrush="#5B4A8A"
            BorderThickness="1"
            Margin="6,6,6,2">
        <Border.Effect>
            <DropShadowEffect BlurRadius="12" Opacity="0.2" ShadowDepth="3" Direction="270" Color="#1A1030"/>
        </Border.Effect>
        <Grid>
            <TextBox x:Name="InputBox" 
                     FontSize="14" 
                     FontFamily="Segoe UI"
                     Background="Transparent" 
                     BorderThickness="0"
                     VerticalContentAlignment="Center" 
                     Margin="16,12"
                     Foreground="#E0D8F0" 
                     CaretBrush="#89B4FA"
                     KeyDown="InputBox_KeyDown"
                     TextChanged="InputBox_TextChanged"/>
            <TextBlock x:Name="HintText"
                       Text="Esc 关闭 | 键入后 Enter 提交"
                       FontSize="14"
                       FontFamily="Segoe UI"
                       Foreground="#7B6FA0"
                       IsHitTestVisible="False"
                       VerticalAlignment="Center"
                       Margin="18,0,18,0"
                       Visibility="Visible"/>
        </Grid>
    </Border>
</Window>
