<Window x:Class="CommitBallBar.PanelWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        Title="CommitBall-Panel"
        WindowStyle="None"
        Background="White"
        ShowInTaskbar="False"
        Topmost="True"
        Focusable="False"
        ShowActivated="False"
        ResizeMode="NoResize"
        Visibility="Hidden">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <wv2:WebView2 x:Name="WebView" Grid.Row="0" />
        <Grid x:Name="DragBar" Grid.Row="1" Height="6" Background="#F0F0F5" Cursor="SizeNS" MouseLeftButtonDown="DragBar_MouseLeftButtonDown">
            <Rectangle HorizontalAlignment="Center" VerticalAlignment="Center" Width="40" Height="2" RadiusX="1" RadiusY="1" Fill="#C0C0CC"/>
        </Grid>
    </Grid>
</Window>
