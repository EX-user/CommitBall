<Window x:Class="CommitBallAgent.AgentWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="CommitBall Agent"
        Width="680" Height="480"
        WindowStyle="None"
        Background="#2C2F3A"
        ShowInTaskbar="False"
        Topmost="True"
        ResizeMode="NoResize"
        Focusable="True"
        KeyDown="Window_KeyDown"
        Loaded="Window_Loaded">
    <Grid>
        <Grid.RowDefinitions>
                <RowDefinition Height="32"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="36"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Background="#1A1D26">
            <TextBlock Foreground="#FFFFFF" FontSize="13"
                       FontFamily="Cascadia Code, Consolas, Courier New" VerticalAlignment="Center" Margin="12,0"
                       Opacity="0.85">
                <Run Text="CommitBall Agent Terminal"/>
            </TextBlock>
            <Button x:Name="BgBtn" Content="▾" 
                    HorizontalAlignment="Right" VerticalAlignment="Center"
                    Width="32" Height="24" Margin="0,0,4,0"
                    FontSize="14" FontFamily="Cascadia Code, Consolas"
                    Foreground="#888" Background="Transparent" BorderThickness="0"
                    Click="BgBtn_Click" Cursor="Hand"
                    ToolTip="隐藏到后台继续运行"/>
        </Grid>

        <RichTextBox Grid.Row="1" x:Name="OutputBox" IsReadOnly="True"
                     Foreground="#C8D8F8" Background="Transparent"
                     FontSize="13" FontFamily="Cascadia Code, Consolas, Courier New"
                     BorderThickness="0" 
                     VerticalScrollBarVisibility="Auto"
                     Padding="8,4" Margin="0" Block.LineHeight="20"
                     PreviewKeyDown="OutputBox_PreviewKeyDown">
            <RichTextBox.Resources>
                <Style TargetType="ScrollBar">
                    <Setter Property="Width" Value="6"/>
                    <Setter Property="Background" Value="Transparent"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="ScrollBar">
                                <Grid>
                                    <Border Background="Transparent" />
                                    <Track x:Name="PART_Track" IsDirectionReversed="True">
                                        <Track.Thumb>
                                            <Thumb>
                                                <Thumb.Template>
                                                    <ControlTemplate TargetType="Thumb">
                                                        <Border Background="#88888888" CornerRadius="3" />
                                                    </ControlTemplate>
                                                </Thumb.Template>
                                            </Thumb>
                                        </Track.Thumb>
                                    </Track>
                                </Grid>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </RichTextBox.Resources>
        </RichTextBox>

        <Grid Grid.Row="2" Background="#3D4058">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" x:Name="PromptSymbol" Text=">" Foreground="#E8915A" FontSize="14"
                       FontFamily="Cascadia Code, Consolas, Courier New"
                       VerticalAlignment="Center" Margin="10,0,4,0"/>
            <Grid Grid.Column="1">
                <TextBox x:Name="InputBox" FontSize="13"
                         FontFamily="Cascadia Code, Consolas, Courier New"
                         Foreground="#E0D8F0" Background="Transparent"
                         BorderThickness="0" VerticalContentAlignment="Center"
                         CaretBrush="#FFFFFF"
                         KeyDown="InputBox_KeyDown"/>
                 <TextBlock x:Name="InputHint" Text="连按 Esc×2 中断模型输出"
                           FontSize="13" FontFamily="Cascadia Code, Consolas, Courier New"
                           Foreground="#6A6A8A" VerticalAlignment="Center"
                           Visibility="Collapsed" IsHitTestVisible="False"/>
            </Grid>
        </Grid>
    </Grid>
</Window>
